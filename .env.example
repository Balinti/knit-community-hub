# Supabase Configuration (Required - available at team level)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Supabase Service Role (Available at team level)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe Configuration (Available at team level)
STRIPE_SECRET_KEY=sk_live_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Stripe Pro Price ID (Optional - hide upgrade button if missing)
STRIPE_PRO_PRICE_ID=price_xxx

# Admin Configuration (Optional - admin pages disabled if not set)
ADMIN_EMAIL_ALLOWLIST=admin@example.com

# Note: STRIPE_WEBHOOK_SECRET not needed - using n8n router for webhook routing
# All checkout sessions include metadata: { app_name: "knit-community-hub" }
